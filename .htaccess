RewriteEngine On
RewriteBase /game-review-php-main/

# Ha a kérés nem létező fájlra vagy mappára mutat,
# akkor az Apache továbbadja az index.php fájlnak.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Egyszerű útvonalkezelés: minden ismeretlen URL az index.php-hez kerül.
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
